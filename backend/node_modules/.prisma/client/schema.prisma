generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════
// USERS & AUTH
// ═══════════════════════════════════════

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatar    String?
  isBlocked Boolean  @default(false)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts         Account[]
  ownedInventories Inventory[]       @relation("InventoryOwner")
  writeAccess      InventoryAccess[]
  items            Item[]
  likes            Like[]
  comments         Comment[]
}

model Account {
  id         String @id @default(cuid())
  provider   String
  providerId String
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

// ═══════════════════════════════════════
// INVENTORIES
// ═══════════════════════════════════════

model Inventory {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("Other")
  imageUrl    String?
  isPublic    Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation("InventoryOwner", fields: [ownerId], references: [id])

  tags           InventoryTag[]
  fields         Field[]
  items          Item[]
  access         InventoryAccess[]
  comments       Comment[]
  customIdFormat CustomIdFormat?

  @@index([ownerId])
  @@index([createdAt])
}

model Tag {
  id          String         @id @default(cuid())
  name        String         @unique
  inventories InventoryTag[]
}

model InventoryTag {
  inventoryId String
  tagId       String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([inventoryId, tagId])
}

model InventoryAccess {
  userId      String
  inventoryId String
  grantedAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@id([userId, inventoryId])
}

// ═══════════════════════════════════════
// CUSTOM ID FORMAT
// ═══════════════════════════════════════

model CustomIdFormat {
  id          String    @id @default(cuid())
  inventoryId String    @unique
  elements    Json      @default("[]")
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════
// CUSTOM FIELDS
// ═══════════════════════════════════════

enum FieldType {
  STRING
  TEXT
  NUMBER
  LINK
  BOOLEAN
}

model Field {
  id          String    @id @default(cuid())
  inventoryId String
  title       String
  description String?
  type        FieldType
  showInTable Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  inventory Inventory        @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  values    ItemFieldValue[]

  @@index([inventoryId, order])
}

// ═══════════════════════════════════════
// ITEMS
// ═══════════════════════════════════════

model Item {
  id          String   @id @default(cuid())
  customId    String
  inventoryId String
  createdById String
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory   Inventory        @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  createdBy   User             @relation(fields: [createdById], references: [id])
  fieldValues ItemFieldValue[]
  likes       Like[]

  @@unique([inventoryId, customId])
  @@index([inventoryId])
  @@index([createdById])
}

model ItemFieldValue {
  id        String   @id @default(cuid())
  itemId    String
  fieldId   String
  valueStr  String?
  valueNum  Float?
  valueBool Boolean?

  item  Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([itemId, fieldId])
  @@index([itemId])
}

// ═══════════════════════════════════════
// SOCIAL FEATURES
// ═══════════════════════════════════════

model Like {
  userId  String
  itemId  String
  likedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([itemId])
}

model Comment {
  id          String   @id @default(cuid())
  text        String
  inventoryId String
  userId      String
  createdAt   DateTime @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([inventoryId, createdAt])
}
